function abrirPizzas(){

    esconderCombos()

    let html = "<h2>🍕 Escolha sua Pizza</h2>"

    const pizzas = [
        {nome:"Calabresa", img:"imagens/calabresa.jpg", desc:"Molho, mussarela, calabresa, cebola"},
        {nome:"Frango com Catupiry", img:"imagens/frango.jpg", desc:"Molho, frango desfiado, catupiry"},
        {nome:"4 Queijos", img:"imagens/4queijos.jpg", desc:"Mussarela, provolone, parmesão, catupiry"},
        {nome:"Portuguesa", img:"imagens/portuguesa.jpg", desc:"Presunto, ovo, cebola, ervilha"},
        {nome:"Marguerita", img:"imagens/marguerita.jpg", desc:"Mussarela, tomate, manjericão"},
        {nome:"Baiana", img:"imagens/baiana.jpg", desc:"Calabresa, ovo, pimenta"},
        {nome:"Napolitana", img:"imagens/napolitana.jpg", desc:"Mussarela, tomate, parmesão"},
        {nome:"Milho com Bacon", img:"imagens/milho.jpg", desc:"Milho, bacon, mussarela"},
        {nome:"Moda da Casa", img:"imagens/moda.jpg", desc:"Especial da casa"}
    ]

    pizzas.forEach(pizza=>{
        html += `
        <div class="card pizza-card">

            <div class="img-wrapper">
                <img src="${pizza.img}" onerror="this.src='imagens/erro.png'">
                
                <div class="overlay-card">
                    <button onclick="abrirMontagemPizza('${pizza.nome}')">
                        🍕 Montar
                    </button>
                </div>
            </div>

            <div class="card-content">
                <h3>${pizza.nome}</h3>
                <p>${pizza.desc}</p>

                <!-- 🔥 BOTÃO PADRÃO IGUAL MENU -->
                <button onclick="abrirMontagemPizza('${pizza.nome}')">
                    🍕 Montar Pizza
                </button>

            </div>

        </div>
        `
    })

    document.getElementById("produtos").innerHTML = html
}
